<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="lt.university.mybatis.dao.DepartmentsMapper">
    <resultMap id="departmentWithStudentsResultMap" type="lt.university.mybatis.model.DepartmentWithStudentsModel">
        <id     property="id"   column="departmentId"/>
        <result property="name" column="departmentName"/>
        <collection property="students" ofType="lt.university.mybatis.model.StudentModel">
            <id     property="id"        column="studentId"/>
            <result property="firstName" column="firstName"/>
            <result property="lastName"  column="lastName"/>
            <result property="email"     column="email"/>
            <result property="courseId"  column="courseId"/>
        </collection>
    </resultMap>
</mapper>
